generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  COUNSELLOR
  ADMIN
}

enum SessionStatus {
  BOOKED
  COMPLETED
  CANCELLED
  PENDING
}

enum TransactionType {
  DEPOSIT
  SESSION_PAYMENT
  WITHDRAWAL
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  password          String?
  role              Role                @default(USER)
  walletBalance     Decimal             @default(0) @db.Decimal(12, 2)
  emailVerified     Boolean             @default(false)
  googleId          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  counsellorProfile CounsellorProfile?
  sessionsAsClient  Session[]           @relation("ClientSessions")
  transactions      Transaction[]
  journals          Journal[]
  blogs             Blog[]
}

model CounsellorProfile {
  id                String              @id @default(cuid())
  userId            String              @unique
  specialization    String
  experienceYears   Int
  sessionRate       Decimal             @db.Decimal(12, 2)
  bio               String
  languages         String[]
  availabilitySlots Json
  verified          Boolean             @default(false)
  rating            Float               @default(0)
  totalSessions     Int                 @default(0)
  sessions          Session[]           @relation("CounsellorSessions")
  withdrawals       WithdrawalRequest[]
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id                 String            @id @default(cuid())
  userId             String
  counsellorId       String
  scheduledTime      DateTime
  status             SessionStatus     @default(BOOKED)
  paymentId          String?
  amount             Decimal           @db.Decimal(12, 2)
  platformCommission Decimal           @db.Decimal(12, 2)
  zoomLink           String?
  createdAt          DateTime          @default(now())
  user               User              @relation("ClientSessions", fields: [userId], references: [id], onDelete: Cascade)
  counsellor         CounsellorProfile @relation("CounsellorSessions", fields: [counsellorId], references: [id], onDelete: Cascade)
  review             Review?

  @@index([scheduledTime])
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  type             TransactionType
  amount           Decimal           @db.Decimal(12, 2)
  status           TransactionStatus
  paymentGatewayId String?
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Journal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  mood      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  sessionId String   @unique
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id           String           @id @default(cuid())
  counsellorId String
  amount       Decimal          @db.Decimal(12, 2)
  status       WithdrawalStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  counsellor   CounsellorProfile @relation(fields: [counsellorId], references: [id], onDelete: Cascade)
}

model PlatformSetting {
  id                   String   @id @default(cuid())
  commissionPercentage Float    @default(20)
  stripeEnabled        Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
